# Authentication - Better Auth
# Generate one with `openssl rand -base64 32` or similar
BETTER_AUTH_SECRET=your_better_auth_secret
BETTER_AUTH_URL=http://localhost:3000

# OAuth - GitHub (Optional)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Cloudflare D1 (For Production)
# Get these from your Cloudflare Dashboard
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_D1_DATABASE_ID=your_database_id
CLOUDFLARE_D1_TOKEN=your_api_token_with_d1_edit_permissions

# Database Mode (optional, if you want manual control)
# DB_MODE=local # or 'prod'
