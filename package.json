{
  "license": "MIT",
  "name": "astro-tailwind-decapcms-starterkit",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "dev": "astro dev --host",
    "start": "astro dev",
    "sync": "astro sync",
    "build:tailwind": "bun x @tailwindcss/cli -i src/styles/global.css -o dist/global.css --minify",
    "build:postcss": "postcss dist/global.css -o dist/global.css",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,md,css,html,yaml,astro}\"",
    "build": "astro check && astro build && bun run build:tailwind && bun run build:postcss",
    "preview": "astro preview --host",
    "prod": "bun run format && bun run build && bun run preview",
    "decap": "bun x decap-server",
    "db:push": "bun drizzle-kit push",
    "db:generate": "bun drizzle-kit generate",
    "db:studio": "bun drizzle-kit studio",
    "db:check": "bun drizzle-kit check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/netlify": "^6.5.1",
    "@astrojs/react": "^4.3.0",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.4.1",
    "@libsql/client": "^0.15.10",
    "@tailwindcss/cli": "^4.1.11",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/vite": "^4.1.11",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "astro": "^5.12.0",
    "astro-capo": "^0.0.1",
    "astro-compress": "^2.3.8",
    "astro-expressive-code": "^0.41.3",
    "astro-icon": "^1.1.5",
    "astro-og-canvas": "^0.7.0",
    "better-auth": "^1.2.12",
    "dotenv": "^17.2.0",
    "drizzle-orm": "^0.44.3",
    "fuse.js": "^7.1.0",
    "ky": "^1.8.2",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "swiper": "^11.2.10",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.57",
    "@tailwindcss/typography": "^0.5.16",
    "@types/netlify-identity-widget": "^1.9.6",
    "drizzle-kit": "^0.31.4",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.14"
  }
}
