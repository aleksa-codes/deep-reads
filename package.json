{
  "license": "MIT",
  "name": "deep-reads",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "dev": "astro dev",
    "dev:host": "astro dev --host",
    "start": "astro dev",
    "sync": "astro sync",
    "build:tailwind": "bun x @tailwindcss/cli -i src/styles/global.css -o dist/global.css --minify",
    "build:postcss": "postcss dist/global.css -o dist/global.css",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,md,css,html,yaml,astro}\"",
    "build": "astro check && astro build && bun run build:tailwind && bun run build:postcss",
    "preview": "astro preview --host",
    "prod": "bun run format && bun run build && bun run preview",
    "decap": "bun x decap-server",
    "db:push": "bun drizzle-kit push",
    "db:push:prod": "NODE_ENV=production bun drizzle-kit push",
    "db:generate": "bun drizzle-kit generate",
    "db:generate:prod": "NODE_ENV=production bun drizzle-kit generate",
    "db:studio": "bun drizzle-kit studio",
    "db:check": "bun drizzle-kit check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/netlify": "^7.0.5",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@libsql/client": "^0.17.2",
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.1",
    "astro-capo": "^0.0.1",
    "astro-compress": "^2.4.0",
    "astro-icon": "^1.1.5",
    "astro-og-canvas": "^0.10.1",
    "better-auth": "^1.5.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.1.0",
    "ky": "^1.14.3",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.100",
    "@tailwindcss/typography": "^0.5.19",
    "@types/netlify-identity-widget": "^1.9.7",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  }
}
