---
// src/components/Search.astro
import { Icon } from 'astro-icon/components';
---

<!-- 1. The visible trigger button -->
<button
  id='search-trigger'
  type='button'
  class='border-input bg-background text-muted-foreground ring-offset-background hover:bg-accent hover:text-accent-foreground flex h-10 w-full max-w-md items-center justify-between gap-2 rounded-md border px-3 py-2 text-sm transition-colors'
  aria-label='Search articles (Press Ctrl+K)'
>
  <div class='flex items-center gap-2'>
    <Icon name='lucide:search' class='h-4 w-4' />
    <span>Search articles...</span>
  </div>
  <kbd
    class='bg-muted pointer-events-none hidden h-5 items-center gap-1 rounded border px-1.5 font-mono text-[10px] font-medium opacity-100 select-none sm:flex'
  >
    <span class='text-xs'>⌘</span>K
  </kbd>
</button>

<!-- 2. The Command Palette Dialog (SIMPLIFIED & CORRECTED) -->
<dialog
  id='search-dialog'
  class='bg-popover text-popover-foreground w-[95vw] rounded-lg border p-0 shadow-lg backdrop:bg-black/50 sm:max-w-xl'
>
  <!-- All content is now directly inside the dialog -->
  <div class='flex items-center border-b px-3'>
    <Icon name='lucide:search' class='mr-2 h-4 w-4 shrink-0 opacity-50' />
    <input
      id='search-input'
      type='text'
      placeholder='Search for news, topics, or sources...'
      class='placeholder:text-muted-foreground flex h-12 w-full rounded-md bg-transparent py-3 text-sm outline-none disabled:cursor-not-allowed disabled:opacity-50'
      autocomplete='off'
    />
  </div>

  <div class='p-2'>
    <div id='search-loader' class='text-muted-foreground hidden py-4 text-center text-sm'>Loading...</div>
    <ul id='search-results-list' class='max-h-[60vh] overflow-x-hidden overflow-y-auto'></ul>
    <div id='search-empty-state' class='hidden py-6 text-center text-sm'>
      <p class='text-muted-foreground mb-2'>No results found.</p>
      <p class='text-muted-foreground/80 text-xs'>Try searching for a different keyword or tag.</p>
    </div>
  </div>
</dialog>

<!-- The script block with minor adjustments -->
<script>
  import Fuse from 'fuse.js';
  import type { FuseResult, IFuseOptions } from 'fuse.js';

  interface ReadItem {
    id: string;
    title: string;
    summary: string;
    tags: string[];
  }

  function escapeRegExp(string: string): string {
    return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  const trigger = document.getElementById('search-trigger') as HTMLButtonElement | null;
  const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
  const input = document.getElementById('search-input') as HTMLInputElement | null;
  const resultsList = document.getElementById('search-results-list') as HTMLUListElement | null;
  const loader = document.getElementById('search-loader') as HTMLDivElement | null;
  const emptyState = document.getElementById('search-empty-state') as HTMLDivElement | null;

  if (!trigger || !dialog || !input || !resultsList || !loader || !emptyState) {
    console.error('Search component failed to initialize: One or more required elements are missing from the DOM.');
  } else {
    let fuse: Fuse<ReadItem> | undefined;
    let searchData: ReadItem[] = [];
    let activeIndex = -1;
    let timeoutId: number | undefined;

    const options: IFuseOptions<ReadItem> = {
      keys: [
        { name: 'title', weight: 0.7 },
        { name: 'tags', weight: 0.3 },
      ],
      includeScore: true,
      minMatchCharLength: 2,
      threshold: 0.4,
    };

    const openSearch = (): void => {
      dialog.showModal();
      dialog.style.marginTop = '15vh'; // Position it from the top
      input.focus();
      if (!fuse) setupSearch();
    };

    const closeSearch = (): void => {
      dialog.close();
      dialog.style.marginTop = ''; // Reset the style on close
    };

    const setupSearch = async (): Promise<void> => {
      loader.classList.remove('hidden');
      try {
        const response = await fetch('/api/search.json');
        if (!response.ok) throw new Error('Failed to load search data');
        searchData = await response.json();
        fuse = new Fuse(searchData, options);
      } catch (error) {
        console.error('Search setup failed:', error);
      } finally {
        loader.classList.add('hidden');
      }
    };

    const performSearch = (query: string): void => {
      if (!fuse) return;
      if (query.length < 2) {
        resultsList.innerHTML = '';
        emptyState.classList.add('hidden');
        return;
      }
      const searchResults = fuse.search(query);
      renderResults(searchResults, query);
    };

    const renderResults = (results: FuseResult<ReadItem>[], query: string): void => {
      resultsList.innerHTML = '';
      activeIndex = -1;
      const highlightRegex = new RegExp(`(${escapeRegExp(query)})`, 'gi');
      if (results.length === 0) {
        emptyState.classList.remove('hidden');
      } else {
        emptyState.classList.add('hidden');
        results.slice(0, 10).forEach((result, index) => {
          const { item } = result;
          const highlightedTitle = item.title.replace(
            highlightRegex,
            `<mark class="bg-primary/20 rounded-sm px-0.5">$1</mark>`,
          );
          const highlightedTags = item.tags
            ?.join(', ')
            .replace(highlightRegex, `<mark class="bg-primary/20 rounded-sm px-0.5">$1</mark>`);
          const li = document.createElement('li');
          li.setAttribute('role', 'option');
          li.setAttribute('aria-selected', 'false');
          li.dataset.index = index.toString();
          li.innerHTML = `
            <a href="/read/${item.id}/" class="block p-3 rounded-md hover:bg-accent focus:bg-accent focus:outline-none">
              <div class="font-semibold text-sm">${highlightedTitle}</div>
              ${highlightedTags ? `<div class="text-xs text-muted-foreground mt-1">${highlightedTags}</div>` : ''}
            </a>
          `;
          resultsList.appendChild(li);
        });
      }
    };

    const updateHighlight = (): void => {
      const items = resultsList.querySelectorAll<HTMLLIElement>('li');
      items.forEach((item, index) => {
        if (index === activeIndex) {
          item.classList.add('bg-accent');
          item.setAttribute('aria-selected', 'true');
          item.scrollIntoView({ block: 'nearest' });
        } else {
          item.classList.remove('bg-accent');
          item.setAttribute('aria-selected', 'false');
        }
      });
    };

    // --- Event Listeners ---
    trigger.addEventListener('click', openSearch);
    dialog.addEventListener('close', closeSearch);

    // Click backdrop to close
    dialog.addEventListener('click', (e: MouseEvent) => {
      if (e.target === dialog) {
        closeSearch();
      }
    });

    input.addEventListener('input', (e: Event) => {
      window.clearTimeout(timeoutId);
      const query = (e.target as HTMLInputElement).value;
      timeoutId = window.setTimeout(() => performSearch(query), 150);
    });
    input.addEventListener('keydown', (e: KeyboardEvent) => {
      const items = resultsList.querySelectorAll('li');
      if (items.length === 0) return;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        activeIndex = (activeIndex + 1) % items.length;
        updateHighlight();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        activeIndex = (activeIndex - 1 + items.length) % items.length;
        updateHighlight();
      } else if (e.key === 'Enter' && activeIndex > -1) {
        e.preventDefault();
        const link = items[activeIndex]?.querySelector('a');
        if (link) {
          link.click();
          closeSearch();
        }
      }
    });
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openSearch();
      }
      if (e.key === 'Escape' && dialog.open) {
        closeSearch();
      }
    });
  }
</script>
