---
import Button from '@/components/ui/button.astro';

const ctaContent = {
  overline: 'Take Action Now',
  title: 'Make your business\nstand out.',
  description: 'Transform your online presence with our sustainable and organic approach to web development.',
  primaryCta: {
    text: 'Get Started',
    href: '/contact/',
  },
};
---

<section class='bg-forest relative flex overflow-hidden bg-cover bg-fixed bg-center bg-no-repeat py-16 sm:py-20'>
  <!-- mask -->
  <div class='bg-background/80 dark:bg-background/90 absolute inset-0 size-full'></div>
  <div class='z-0 container text-center'>
    <div class='mx-auto max-w-4xl space-y-4 text-center sm:space-y-6'>
      <span class='text-secondary text-base font-semibold tracking-wide uppercase'>{ctaContent.overline}</span>
      <h2 class='text-primary text-3xl leading-tight font-bold sm:text-4xl md:text-5xl lg:text-6xl'>
        {ctaContent.title}
      </h2>
      <p class='text-muted-foreground mx-auto max-w-2xl text-base leading-relaxed sm:text-lg md:text-xl'>
        {ctaContent.description}
      </p>
      <div class='flex flex-col items-center justify-center gap-3 pt-4 sm:flex-row sm:gap-4'>
        <Button href={ctaContent.primaryCta.href} size='lg'>
          {ctaContent.primaryCta.text}
        </Button>
      </div>
    </div>
  </div>
</section>
