---
import { Image } from 'astro:assets';
// Dynamic logo loading
const logos = import.meta.glob<{ default: ImageMetadata }>('@/assets/logos/*.{svg,png,jpg,jpeg}');

const loadedLogos = await Promise.all(
  Object.entries(logos).map(async ([path, loader]) => {
    const { default: logo } = await loader();
    // Extract name from file path (e.g., '/src/assets/logos/vercel.svg' -> 'vercel')
    const name = path.split('/').pop()?.split('.')[0] ?? '';
    return { name, logo };
  }),
);
---

<section class='border-border bg-muted h-40 border-y py-4 sm:h-48'>
  <div class='container'>
    <h2
      class='text-muted-foreground mb-6 px-4 text-center font-sans text-sm font-semibold tracking-wide uppercase sm:mb-8 sm:text-base'
    >
      Trusted by industry leaders worldwide
    </h2>
    <div
      class='flex gap-4 overflow-hidden [mask-image:linear-gradient(to_right,transparent,black_20%,black_80%,transparent_100%)] sm:gap-8'
    >
      {
        Array(5)
          .fill(null)
          .map((_) => (
            <div class='logo-scroll animate-logo-cloud-sm sm:animate-logo-cloud mx-2 flex shrink-0 gap-8 sm:mx-4 sm:gap-16'>
              {loadedLogos.map(({ name, logo }) => (
                <div class='py-2 sm:py-3'>
                  <Image
                    src={logo}
                    alt={`${name} logo`}
                    loading={'eager'}
                    class='h-12 w-auto max-w-24 opacity-60 brightness-0 transition-all duration-300 hover:scale-110 hover:opacity-100 sm:h-20 dark:invert'
                  />
                </div>
              ))}
            </div>
          ))
      }
    </div>
  </div>
</section>

<script>
  // Only run on devices that support hover
  const hasHover = window.matchMedia('(hover: hover)').matches;

  if (hasHover) {
    const scrollers = document.getElementsByClassName('logo-scroll') as HTMLCollectionOf<HTMLElement>;

    const pauseScroll = (isPaused: boolean) => {
      Array.from(scrollers).forEach((scroller) => {
        scroller.style.animationPlayState = isPaused ? 'paused' : 'running';
      });
    };

    document.addEventListener('mouseover', (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName === 'IMG') pauseScroll(true);
    });

    document.addEventListener('mouseout', (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName === 'IMG') pauseScroll(false);
    });
  }
</script>
