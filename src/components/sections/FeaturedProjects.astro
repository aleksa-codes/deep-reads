---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import Button from '@/components/ui/button.astro';

interface Props {
  projects: Array<{
    title: string;
    description: string;
    image: ImageMetadata;
    link: string;
  }>;
}

const { projects } = Astro.props;
---

<section class='bg-background py-16 sm:py-20'>
  <div class='container'>
    <div class='mx-auto max-w-2xl text-center'>
      <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Featured Projects</h2>
      <p class='text-muted-foreground mt-4 text-lg'>Take a closer look at some of our best work</p>
    </div>

    <div class='mt-16'>
      <div class='relative'>
        <div class='swiper gallery-slider overflow-hidden'>
          <div class='swiper-wrapper'>
            {
              projects.map((project) => (
                <div class='swiper-slide px-0.5'>
                  <div class='group relative overflow-hidden rounded-xl'>
                    <div class='aspect-[4/3]'>
                      <Image
                        src={project.image}
                        alt={project.title}
                        format={'webp'}
                        quality={'max'}
                        class='h-full w-full object-cover'
                      />
                    </div>
                    <div class='from-primary/90 absolute inset-0 flex flex-col justify-end bg-gradient-to-t to-transparent p-8'>
                      <h3 class='text-primary-foreground mt-2 text-xl font-semibold'>{project.title}</h3>
                      <p class='text-primary-foreground mt-2 text-sm'>{project.description}</p>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <div class='absolute top-1/2 -left-3 z-10 -translate-y-1/2'>
          <Button variant='outline' size='icon' class='gallery-prev-btn'>
            <Icon name='lucide:chevron-left' class='h-5 w-5' />
          </Button>
        </div>
        <div class='absolute top-1/2 -right-3 z-10 -translate-y-1/2'>
          <Button variant='outline' size='icon' class='gallery-next-btn'>
            <Icon name='lucide:chevron-right' class='h-5 w-5' />
          </Button>
        </div>
      </div>

      <div class='mt-8 flex justify-center'>
        <div
          class='gallery-pagination [&>.swiper-pagination-bullet]:bg-primary/25 [&>.swiper-pagination-bullet-active]:!bg-primary inline-flex items-center justify-center gap-1 [&>.swiper-pagination-bullet]:h-2 [&>.swiper-pagination-bullet]:w-2 [&>.swiper-pagination-bullet]:cursor-pointer [&>.swiper-pagination-bullet]:rounded-full [&>.swiper-pagination-bullet]:transition-colors'
        >
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Autoplay, Pagination, Navigation } from 'swiper/modules';
  import 'swiper/css/bundle';

  new Swiper('.gallery-slider', {
    modules: [Autoplay, Pagination, Navigation],
    slidesPerView: 1,
    spaceBetween: 32,
    loop: true,
    autoplay: { delay: 5000 },
    pagination: {
      el: '.gallery-pagination',
      clickable: true,
    },
    navigation: {
      prevEl: '.gallery-prev-btn',
      nextEl: '.gallery-next-btn',
    },
    breakpoints: {
      640: { slidesPerView: 2 },
      1024: { slidesPerView: 3 },
    },
  });
</script>
