---
import Button from '@/components/ui/button.astro';
---

<section
  class='bg-forest relative flex min-h-dvh items-center justify-center bg-cover bg-center bg-no-repeat px-4 py-16 sm:py-20 md:bg-fixed md:py-32'
>
  <!-- mask -->
  <div class='bg-background/80 dark:bg-background/90 absolute inset-0 size-full'></div>
  <div class='z-0 container text-center'>
    <div class='space-y-6 sm:space-y-8'>
      <span class='text-secondary inline-block text-base font-bold tracking-wider uppercase'>
        Custom Web Design & Development
      </span>
      <h1 class='flex flex-col gap-2 text-4xl sm:text-5xl md:text-6xl lg:text-7xl'>
        <span class='font-bold'>Transform Your Vision</span>
        <span
          class='animate-text-shine bg-[linear-gradient(135deg,var(--primary)_0%,var(--primary)_45%,var(--background)_50%,var(--primary)_55%,var(--primary)_100%)] bg-[length:200%_auto] bg-clip-text font-black text-transparent sm:pb-2 dark:bg-[linear-gradient(135deg,var(--primary)_0%,var(--primary)_45%,var(--foreground)_50%,var(--primary)_55%,var(--primary)_100%)]'
          >Into Digital Reality</span
        >
      </h1>
      <p class='mx-auto max-w-2xl text-lg leading-relaxed sm:text-xl md:text-2xl'>
        Hand-crafted websites that deliver exceptional results. No templates, no compromises - just pure, custom-coded
        excellence for your business.
      </p>
      <div class='flex flex-col gap-4 sm:flex-row sm:justify-center sm:gap-6'>
        <Button size='lg' href='/contact/'>Get Started</Button>
        <Button size='lg' href='#pricing' variant={'secondary'}>View Pricing</Button>
      </div>
    </div>
  </div>
</section>
