---
import { Icon } from 'astro-icon/components';

const testimonials = [
  {
    content:
      'As a software startup, we needed a website that could grow with us. Forest Designs delivered exactly that - a scalable, modern platform that perfectly represents our brand. Their attention to detail and technical expertise made the entire process seamless.',
    author: 'Sarah Chen',
    position: 'TechFlow, CEO',
  },
  {
    content:
      "Working with Forest Designs transformed our online presence. Their creative approach and technical skills helped us achieve a 40% increase in user engagement. The team's commitment to quality is outstanding.",
    author: 'Michael Roberts',
    position: 'EcoSolutions, Founder',
  },
  {
    content:
      "The team at Forest Designs doesn't just build websites; they create digital experiences. Their understanding of UX/UI principles and modern web technologies resulted in a site that our customers love to use.",
    author: 'Emma Thompson',
    position: 'Innovate Labs, Director',
  },
  {
    content:
      'Forest Designs brought our vision to life with precision and creativity. Their collaborative approach and technical expertise made them the perfect partner for our digital transformation journey.',
    author: 'David Martinez',
    position: 'NextGen Systems, CTO',
  },
];
---

<section class='bg-muted py-16 sm:py-20'>
  <div class='container'>
    <div class='mx-auto max-w-2xl text-center'>
      <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Client Testimonials</h2>
      <p class='text-muted-foreground mt-4 text-lg'>See what our clients say about working with us</p>
    </div>

    <div class='mt-16'>
      <div class='swiper testimonials-slider'>
        <div class='swiper-wrapper'>
          {
            testimonials.map((testimonial) => (
              <div class='swiper-slide px-4'>
                <div class='bg-background relative h-full overflow-hidden rounded-xl border p-8'>
                  <div class='absolute top-4 right-4 opacity-10'>
                    <Icon name='lucide:quote' class='text-primary h-16 w-16' />
                  </div>
                  <div class='relative space-y-6'>
                    <p class='text-muted-foreground text-lg leading-relaxed'>{testimonial.content}</p>
                    <div class='flex items-center gap-4 border-t pt-6'>
                      <div class='bg-primary/10 flex h-12 w-12 items-center justify-center rounded-full'>
                        <Icon name='lucide:user' class='text-primary h-6 w-6' />
                      </div>
                      <div>
                        <p class='text-foreground font-semibold'>{testimonial.author}</p>
                        <p class='text-muted-foreground text-sm'>{testimonial.position}</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div class='mt-8'>
        <div
          class='testimonials-pagination [&>.swiper-pagination-bullet]:bg-primary/25 [&>.swiper-pagination-bullet-active]:!bg-primary inline-flex flex-row items-center justify-center gap-1 [&>.swiper-pagination-bullet]:h-2 [&>.swiper-pagination-bullet]:w-2 [&>.swiper-pagination-bullet]:cursor-pointer [&>.swiper-pagination-bullet]:rounded-full [&>.swiper-pagination-bullet]:transition-colors'
        >
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import Swiper from 'swiper';
  import { Autoplay, Pagination } from 'swiper/modules';
  import 'swiper/css/bundle';

  new Swiper('.testimonials-slider', {
    modules: [Autoplay, Pagination],
    spaceBetween: 32,
    slidesPerView: 1,
    loop: true,
    autoplay: {
      delay: 5000,
      disableOnInteraction: false,
    },
    pagination: {
      el: '.testimonials-pagination',
      clickable: true,
    },
    breakpoints: {
      768: {
        slidesPerView: 2,
      },
      1280: {
        slidesPerView: 3,
      },
    },
  });
</script>
