---
import { Icon } from 'astro-icon/components';
import { cn } from '@/lib/utils';

interface Props {
  page: {
    currentPage: number;
    lastPage: number;
    url: {
      prev?: string;
      next?: string;
    };
  };
}

const { page } = Astro.props;
---

