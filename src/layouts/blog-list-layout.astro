---
import Layout from '@/layouts/layout.astro';
import { tagToSlug } from '@/lib/utils';
import type { CollectionEntry } from 'astro:content';
import Top from '@/components/top.astro'; // updated import
import Button from '@/components/ui/button.astro';
import Badge from '@/components/ui/badge.astro';
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
  nofollow?: boolean;
  page: {
    data: CollectionEntry<'blog'>[];
    currentPage: number;
    lastPage: number;
    url: {
      prev?: string;
      next?: string;
    };
  };
  allTags: string[];
}

const { title, description, noindex, nofollow, page, allTags } = Astro.props;
---

<Layout title={title} description={description} noindex={noindex} nofollow={nofollow}>
  <Top title={title} description={description} />

  <section class='bg-background py-16 sm:py-20'>
    <div class='container'>
      <div class='grid grid-cols-1 gap-8 lg:grid-cols-3'>
        <!-- Main Content -->
        <div class='lg:col-span-2'>
          <div class='grid grid-cols-1 gap-8 md:grid-cols-2'>
            {
              page.data.map((post) => (
                <article class='bg-muted rounded-2xl p-8 transition-shadow hover:shadow-lg'>
                  <div class='space-y-6'>
                    {post.data.thumbnail && (
                      <div class='aspect-video overflow-hidden rounded-md'>
                        <a href={`/blog/${post.id}/`}>
                          <Image
                            src={post.data.thumbnail}
                            alt={post.data.title}
                            format={'webp'}
                            quality={'max'}
                            class='size-full object-cover transition-transform duration-300 hover:scale-110'
                          />
                        </a>
                      </div>
                    )}
                    <div class='space-y-4'>
                      <h2 class='text-foreground text-2xl font-bold tracking-tight'>
                        <a href={`/blog/${post.id}/`} class='hover:text-primary'>
                          {post.data.title}
                        </a>
                      </h2>
                      <div class='text-muted-foreground flex items-center gap-4'>
                        <time datetime={post.data.date.toISOString()}>
                          {post.data.date.toLocaleDateString('en-us', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric',
                          })}
                        </time>
                        <span>•</span>
                        <span>{post.data.author}</span>
                      </div>
                      <p class='text-muted-foreground'>{post.data.description}</p>
                      {post.data.tags?.length > 0 && (
                        <div class='flex flex-wrap gap-2'>
                          {post.data.tags.map((tag) => (
                            <Badge as='a' href={`/blog/${tagToSlug(tag)}/`} variant='outline' size='sm'>
                              {tag}
                            </Badge>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                </article>
              ))
            }
          </div>

          <!-- Pagination Controls -->
          {
            page.lastPage > 1 && (
              <div class='mt-12 flex items-center justify-center gap-2'>
                <Button
                  href={page.url.prev || '#'}
                  variant='outline'
                  size='icon'
                  disabled={!page.url.prev}
                  aria-label='Previous Page'
                >
                  <Icon name='lucide:chevron-left' />
                </Button>
                <div class='border-border h-10 rounded-md border px-4 py-2 text-sm'>
                  Page {page.currentPage} of {page.lastPage}
                </div>
                <Button
                  href={page.url.next || '#'}
                  variant='outline'
                  size='icon'
                  disabled={!page.url.next}
                  aria-label='Next Page'
                >
                  <Icon name='lucide:chevron-right' />
                </Button>
              </div>
            )
          }
        </div>

        <!-- Sidebar -->
        <div class='h-full'>
          <div class='bg-muted space-y-8 rounded-2xl p-8 lg:sticky lg:top-20'>
            <!-- Categories -->
            <div class='space-y-4'>
              <h2 class='text-xl font-bold'>Categories</h2>
              <div class='flex flex-wrap gap-2'>
                {
                  allTags.map((tag) => (
                    <Badge as='a' href={`/blog/${tagToSlug(tag)}/`} variant='outline'>
                      {tag}
                    </Badge>
                  ))
                }
              </div>
            </div>

            <div class='bg-border h-px'></div>

            <!-- Subscribe -->
            <div class='space-y-4'>
              <h2 class='text-xl font-bold'>Subscribe</h2>
              <p class='text-muted-foreground'>Sign up to receive the latest news and offers from Forest Designs.</p>
              <form class='relative'>
                <input
                  type='email'
                  placeholder='Email address...'
                  class='border-border/40 bg-background ring-offset-background placeholder:text-muted-foreground/60 focus:ring-primary/20 w-full rounded-md border px-4 py-2.5 pr-12 text-sm focus:ring-2 focus:outline-hidden'
                  required
                />
                <Button
                  type='submit'
                  variant='ghost'
                  size='icon'
                  class='absolute top-1/2 right-2 size-8 -translate-y-1/2'
                  aria-label='Subscribe to newsletter'
                >
                  <Icon name='lucide:arrow-right' />
                </Button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
