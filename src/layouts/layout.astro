---
import Footer from '@/components/footer.astro';
import BaseHead from '@/components/base-head.astro';
import TailwindIndicator from '@/components/tailwind-indicator.astro';
import ThemeToggle from '@/components/theme-toggle.astro';
import Search from '@/components/search';
import AuthButton from '@/components/auth-button';
import { cn } from '@/lib/utils';
import { siteConfig } from '@/config/site.config';
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  image?: string;
  ogType?: string;
  noindex?: boolean;
  nofollow?: boolean;
  twitterCreator?: string;
  twitterSite?: string;
  schema?: {
    type: string;
    date?: Date;
    author?: string;
    tags?: string[];
  };
}

const { title, description, image, ogType, schema, noindex, nofollow, twitterCreator, twitterSite } = Astro.props;

// Determine active path for navigation styling
const currentPath = Astro.url.pathname;
const isReadsActive = currentPath === '/' || currentPath.startsWith('/read');
const isTagsActive = currentPath.startsWith('/tags');
---

<!doctype html>
<html lang='en'>
  <head>
    <BaseHead {title} {description} {image} {ogType} {noindex} {nofollow} {twitterCreator} {twitterSite} {schema} />
  </head>
  <body class='bg-background min-h-screen font-sans antialiased'>
    <!-- HEADER -->
    <header class='border-border bg-background/80 sticky top-0 z-50 border-b backdrop-blur-sm'>
      <div class='container flex h-16 items-center justify-between md:grid md:grid-cols-3 md:gap-4'>
        <!-- Left Column (Grid Col 1 on Desktop) -->
        <div class='flex items-center justify-start'>
          <a href='/' class='flex items-center gap-2.5' aria-label={`${siteConfig.title} Homepage`}>
            <div class='bg-muted/50 flex size-8 items-center justify-center rounded-lg border'>
              <Icon name='lucide:book-open' class='text-muted-foreground h-4 w-4' />
            </div>
            {
              /* 
              ============================================================
              MODIFICATION: 
              - Removed `hidden sm:inline` to show the title on all screens.
              - Adjusted font size to `text-lg sm:text-xl` for better mobile balance.
              ============================================================
            */
            }
            <span class='text-foreground font-sans text-lg font-bold sm:text-xl'>{siteConfig.title}</span>
          </a>
        </div>

        <!-- Center Column (Grid Col 2 on Desktop, HIDDEN on Mobile) -->
        <nav class='hidden justify-self-center md:block'>
          <div class='border-border bg-muted/50 flex gap-1 rounded-full border p-1'>
            <a
              href='/'
              class={cn(
                'rounded-full px-5 py-1.5 text-sm font-medium transition-colors',
                isReadsActive
                  ? 'bg-primary text-primary-foreground'
                  : 'text-muted-foreground hover:bg-accent hover:text-foreground',
              )}
            >
              Reads
            </a>
            <a
              href='/tags/'
              class={cn(
                'rounded-full px-5 py-1.5 text-sm font-medium transition-colors',
                isTagsActive
                  ? 'bg-primary text-primary-foreground'
                  : 'text-muted-foreground hover:bg-accent hover:text-foreground',
              )}
            >
              Tags
            </a>
          </div>
        </nav>

        <!-- Right Column (Grid Col 3 on Desktop) -->
        <div class='flex items-center justify-end gap-2'>
          <Search client:load />
          <ThemeToggle />
          <AuthButton client:load />
        </div>
      </div>
    </header>

    <!-- MAIN CONTENT AREA -->
    <main class='container py-12 pb-28 md:py-16 md:pb-16'>
      <slot />
    </main>

    <Footer />
    <TailwindIndicator />

    <!-- MOBILE-ONLY BOTTOM NAVIGATION -->
    <nav
      class='border-border bg-background/80 fixed right-0 bottom-0 left-0 z-50 block border-t backdrop-blur-sm md:hidden'
    >
      <div class='container grid h-16 grid-cols-2 items-center text-center'>
        <a
          href='/'
          class={cn(
            'flex flex-col items-center gap-1 py-2 transition-colors',
            isReadsActive ? 'text-primary' : 'text-muted-foreground hover:text-foreground',
          )}
        >
          <Icon name='lucide:newspaper' class='h-6 w-6' />
          <span class='text-xs font-medium'>Reads</span>
        </a>
        <a
          href='/tags/'
          class={cn(
            'flex flex-col items-center gap-1 py-2 transition-colors',
            isTagsActive ? 'text-primary' : 'text-muted-foreground hover:text-foreground',
          )}
        >
          <Icon name='lucide:tag' class='h-6 w-6' />
          <span class='text-xs font-medium'>Tags</span>
        </a>
      </div>
    </nav>
  </body>
</html>
