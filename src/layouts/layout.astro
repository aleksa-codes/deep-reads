---
import CTA from '@/components/sections/CTA.astro';
import Footer from '@/components/footer.astro';
import BaseHead from '@/components/base-head.astro';
import TailwindIndicator from '@/components/tailwind-indicator.astro';
import ThemeToggle from '@/components/theme-toggle.astro';
import Search from '@/components/search'; // Ensure this is using the .tsx extension
import AuthButton from '@/components/auth-button'; // 1. Import the new React component
import { cn } from '@/lib/utils';
// import { auth } from '@/lib/auth'; // Import the auth client
// You can optionally get the session here if you need it for server-rendered content
// but the React component will handle its own state on the client.
// import { auth } from '../lib/auth';
// const session = await auth.api.getSession({ headers: Astro.request.headers });

// export const prerender = false; // Not needed in 'server' mode

// const session = await auth.api.getSession({
//   headers: Astro.request.headers,
// });

interface Props {
  title: string;
  description: string;
  image?: string;
  ogType?: string;
  noindex?: boolean;
  nofollow?: boolean;
  twitterCreator?: string;
  twitterSite?: string;
  hideCTA?: boolean;
  schema?: {
    type: string;
    date?: Date;
    author?: string;
    tags?: string[];
  };
}

const { title, description, image, ogType, schema, noindex, nofollow, twitterCreator, twitterSite, hideCTA } =
  Astro.props;
---

<!doctype html>
<html lang='en'>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      ogType={ogType}
      noindex={noindex}
      nofollow={nofollow}
      twitterCreator={twitterCreator}
      twitterSite={twitterSite}
      schema={schema}
    />
  </head>
  <body class='bg-background min-h-screen font-sans antialiased'>
    <header class='bg-card border-b'>
      <div class='container mx-auto flex flex-col items-center px-4 pt-8 pb-6 text-center'>
        <div class='mb-2 flex w-full items-center'>
          {/* Logo takes up remaining space and is centered by the parent's items-center */}
          <div class='flex-1'></div>
          <h1
            class='from-primary via-chart-2 to-chart-3 bg-gradient-to-r bg-clip-text text-4xl font-extrabold tracking-tight text-transparent drop-shadow-sm'
          >
            DeepReads
          </h1>
          {/* Container for right-aligned items */}
          <div class='ml-auto flex flex-1 items-center justify-end gap-4'>
            <ThemeToggle />
            <AuthButton client:load />
            {/* 2. Add the component with client:load */}
          </div>
        </div>

        <p class='text-muted-foreground mb-6 text-lg'>Your daily digest of what matters</p>

        <div class='mb-6 w-full max-w-md'>
          <Search client:load />
        </div>

        <nav class='flex justify-center'>
          <div class='bg-muted flex gap-2 rounded-full p-1 shadow-sm'>
            <a
              href='/'
              class={cn(
                'rounded-full px-5 py-2 text-base font-medium transition-colors',
                !Astro.url.pathname.startsWith('/tags')
                  ? 'bg-primary text-primary-foreground shadow'
                  : 'text-secondary-foreground hover:bg-accent hover:text-accent-foreground',
              )}
            >
              Reads
            </a>
            <a
              href='/tags/'
              class={cn(
                'rounded-full px-5 py-2 text-base font-medium transition-colors',
                Astro.url.pathname.startsWith('/tags')
                  ? 'bg-primary text-primary-foreground shadow'
                  : 'text-secondary-foreground hover:bg-accent hover:text-accent-foreground',
              )}
            >
              Tags
            </a>
          </div>
        </nav>
      </div>
    </header>
    <main class='container mx-auto px-4 py-8'>
      <slot />
    </main>
    {!hideCTA && <CTA />}
    <Footer />
    <TailwindIndicator />
  </body>
</html>
