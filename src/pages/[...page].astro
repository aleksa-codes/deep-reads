---
import { getCollection } from 'astro:content';
import { siteConfig } from '@/config/site.config';
import Layout from '@/layouts/layout.astro';
import Pagination from '@/components/ui/pagination.astro';
import { Icon } from 'astro-icon/components';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const reads = await getCollection('reads');
  const allTags = await getCollection('tags');
  const sortedReads = reads.sort((a, b) => b.data.dateAdded.valueOf() - a.data.dateAdded.valueOf());
  const allTagInfo = allTags.map((tag) => ({
    slug: tag.id,
    title: tag.data.title,
  }));
  return paginate(sortedReads, {
    pageSize: 4,
    props: { allTagInfo },
  });
}) satisfies GetStaticPaths;

const { page, allTagInfo } = Astro.props;

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
};
---

<Layout title={siteConfig.title} description={siteConfig.description}>
  <div class='divide-border divide-y'>
    {
      page.data.map((read) => (
        <article class='py-10 md:py-12'>
          <div class='grid grid-cols-1 gap-x-8 gap-y-4 md:grid-cols-4'>
            <aside class='text-muted-foreground col-span-1 text-sm md:text-right'>
              <time datetime={read.data.dateAdded.toISOString()}>{formatDate(read.data.dateAdded)}</time>
              <div class='mt-2 flex flex-wrap gap-x-2 gap-y-1 md:justify-end'>
                {read.data.tags.slice(0, 3).map((tagSlug) => {
                  const tag = allTagInfo.find((t) => t.slug === tagSlug);
                  if (!tag) return null;
                  return (
                    <a href={`/tags/${tag.slug}/`} class='hover:text-primary relative transition-colors'>
                      {tag.title}
                    </a>
                  );
                })}
              </div>
            </aside>

            <div class='col-span-1 md:col-span-3'>
              <h2 class='text-foreground text-2xl leading-snug font-bold tracking-tight sm:text-3xl'>
                <a
                  href={`/read/${read.id}/`}
                  class='from-primary to-primary bg-gradient-to-r bg-[length:0%_2px] bg-left-bottom bg-no-repeat transition-all duration-200 hover:bg-[length:100%_2px]'
                >
                  {read.data.title}
                </a>
              </h2>

              {read.data.summary && (
                <p class='text-muted-foreground mt-3 line-clamp-3 text-base leading-relaxed'>{read.data.summary}</p>
              )}

              <a
                href={`/read/${read.id}/`}
                class='group text-primary mt-4 inline-flex items-center text-sm font-medium'
              >
                <span>Read full story</span>
                <Icon name='lucide:arrow-right' class='ml-1.5 h-4 w-4 transition-transform group-hover:translate-x-1' />
              </a>
            </div>
          </div>
        </article>
      ))
    }
  </div>

  {
    page.lastPage > 1 && (
      <div class='mt-12'>
        <Pagination {page} />
      </div>
    )
  }

  {
    page.data.length === 0 && (
      <div class='border-border flex flex-col items-center justify-center rounded-lg border-2 border-dashed py-24 text-center'>
        <Icon name='lucide:archive' class='text-muted-foreground h-12 w-12' />
        <h2 class='text-foreground mt-4 text-2xl font-semibold tracking-tight'>No Reads Yet</h2>
        <p class='text-muted-foreground mt-2'>Check back later for new articles and insights.</p>
      </div>
    )
  }
</Layout>

<script>
  const urlParams = new URLSearchParams(window.location.hash.substring(1));
  const tokenTypes = ['invite_token', 'confirmation_token', 'recovery_token', 'email_change_token'];
  tokenTypes.forEach((tokenType) => {
    if (urlParams.has(tokenType)) {
      window.location.href = `/admin/#${tokenType}=${urlParams.get(tokenType)}`;
    }
  });
</script>
