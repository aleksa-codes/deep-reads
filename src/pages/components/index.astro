---
import Layout from '@/layouts/layout.astro';
import Top from '@/components/top.astro'; // updated import
import FeaturedProjects from '@/components/sections/FeaturedProjects.astro';
import ProjectGrid from '@/components/sections/ProjectGrid.astro';
import Testimonials from '@/components/sections/Testimonials.astro';
import PromoSlider from '@/components/sections/PromoSlider.astro';

// Import your local images
import ecoHarvestImg from '@/assets/portfolio/eco-harvest.jpg';
import zenithFitnessImg from '@/assets/portfolio/zenith-fitness.jpg';
import artisanCoffeeImg from '@/assets/portfolio/artisan-coffee.jpg';
import mountainTrekImg from '@/assets/portfolio/mountain-trek.jpg';
import urbanLoftImg from '@/assets/portfolio/urban-loft.jpg';
import wellnessRetreatImg from '@/assets/portfolio/wellness-retreat.jpg';

const projects = [
  {
    title: 'Eco Harvest Market',
    description:
      'A modern e-commerce platform for an organic food marketplace, featuring a clean design that emphasizes fresh produce and sustainable living.',
    image: ecoHarvestImg,
    link: '#',
  },
  {
    title: 'Zenith Fitness',
    description:
      'Mobile-first website for a boutique fitness studio, with class scheduling and member dashboard integration.',
    image: zenithFitnessImg,
    link: '#',
  },
  {
    title: 'Artisan Coffee Co',
    description:
      'Brand identity and e-commerce solution for a specialty coffee roaster, featuring an online store and subscription service.',
    image: artisanCoffeeImg,
    link: '#',
  },
  {
    title: 'Mountain Trek Adventures',
    description:
      'Adventure tourism website with interactive trail maps and booking system for guided hiking experiences.',
    image: mountainTrekImg,
    link: '#',
  },
  {
    title: 'Urban Loft Real Estate',
    description:
      'Property listing platform with virtual tours and neighborhood insights for a luxury real estate agency.',
    image: urbanLoftImg,
    link: '#',
  },
  {
    title: 'Wellness Retreat Spa',
    description: 'Tranquil website design for a day spa, featuring online booking and gift card purchases.',
    image: wellnessRetreatImg,
    link: '#',
  },
];
---

<Layout title='Components' description='List of random useful components'>
  <Top
    title='UI Components Gallery'
    description='A showcase of reusable components built with Astro and Tailwind CSS'
  />
  <FeaturedProjects projects={projects} />
  <ProjectGrid projects={projects} />
  <Testimonials />
  <PromoSlider imagePosition='left' />
  <PromoSlider imagePosition='right' />
</Layout>
