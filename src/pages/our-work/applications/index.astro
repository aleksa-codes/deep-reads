---
import Layout from '@/layouts/layout.astro';
import { Icon } from 'astro-icon/components';
import Top from '@/components/top.astro';

const features = [
  {
    title: 'Custom Web Applications',
    description: 'Tailored solutions that automate your business processes and improve efficiency.',
    icon: 'lucide:code',
  },
  {
    title: 'Cloud Integration',
    description: 'Seamless integration with cloud services and third-party APIs.',
    icon: 'lucide:cloud',
  },
  {
    title: 'Scalable Architecture',
    description: 'Built to grow with your business needs and user base.',
    icon: 'lucide:layers',
  },
  {
    title: 'Real-time Updates',
    description: 'Live data synchronization for collaborative applications.',
    icon: 'lucide:refresh-cw',
  },
  {
    title: 'Security First',
    description: 'Enterprise-grade security with data encryption and authentication.',
    icon: 'lucide:shield',
  },
  {
    title: 'API Integration',
    description: 'Connect with existing systems and third-party services.',
    icon: 'lucide:plug',
  },
];

const appTypes = [
  {
    title: 'CRM Systems',
    description: 'Custom customer relationship management solutions',
    icon: 'lucide:users',
  },
  {
    title: 'ERP Software',
    description: 'Enterprise resource planning applications',
    icon: 'lucide:building',
  },
  {
    title: 'Booking Systems',
    description: 'Appointment and reservation management',
    icon: 'lucide:calendar',
  },
];

const developmentProcess = [
  {
    step: '01',
    title: 'Requirements Analysis',
    description: 'Deep dive into your business processes and needs',
  },
  {
    step: '02',
    title: 'Architecture Design',
    description: 'Planning scalable and maintainable solution',
  },
  {
    step: '03',
    title: 'Development & Testing',
    description: 'Agile development with continuous testing',
  },
  {
    step: '04',
    title: 'Deployment & Support',
    description: 'Smooth launch and ongoing maintenance',
  },
];

const caseStudies = [
  {
    title: 'Healthcare Management System',
    description: 'Custom EHR system with patient portal',
    results: '45% reduction in administrative tasks',
    image: 'https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=1000',
  },
  {
    title: 'Real Estate Platform',
    description: 'Property management solution',
    results: '200% increase in agent efficiency',
    image: 'https://images.unsplash.com/photo-1560518883-ce09059eeffa?q=80&w=1000',
  },
];

const techFeatures = [
  {
    category: 'Frontend',
    items: ['React/Next.js', 'TypeScript', 'Tailwind CSS'],
    icon: 'lucide:layout',
  },
  {
    category: 'Backend',
    items: ['Node.js', 'Python', 'PostgreSQL'],
    icon: 'lucide:server',
  },
  {
    category: 'DevOps',
    items: ['Docker', 'AWS', 'CI/CD'],
    icon: 'lucide:settings',
  },
];
---

<Layout
  title='Applications'
  description='Transform your business with custom web applications. Modern, scalable, and secure solutions for enterprise needs.'
>
  <Top
    title='Custom Web Applications'
    description='Transform your business with custom web applications. Modern, scalable, and secure solutions for enterprise needs.'
  />

  <!-- Application Types -->
  <section class='bg-muted py-16 sm:py-20'>
    <div class='container'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>
          Custom Applications for Every Need
        </h2>
        <p class='text-muted-foreground mt-4 text-lg'>From simple automation tools to complex enterprise systems</p>
      </div>

      <div class='mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3'>
        {
          appTypes.map((type) => (
            <div class='bg-background rounded-2xl p-8'>
              <div class='bg-primary/10 flex h-12 w-12 items-center justify-center rounded-lg'>
                <Icon name={type.icon} class='text-primary h-6 w-6' />
              </div>
              <h3 class='text-foreground mt-6 text-xl font-semibold'>{type.title}</h3>
              <p class='text-muted-foreground mt-2'>{type.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Development Process -->
  <section class='bg-background py-16 sm:py-20'>
    <div class='container'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Our Development Process</h2>
        <p class='text-muted-foreground mt-4 text-lg'>Agile methodology for predictable delivery and quality results</p>
      </div>

      <div class='mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4'>
        {
          developmentProcess.map((step) => (
            <div class='bg-muted relative rounded-2xl p-8'>
              <span class='text-primary absolute -top-4 left-4 text-5xl font-bold'>{step.step}</span>
              <h3 class='text-foreground mt-4 text-xl font-semibold'>{step.title}</h3>
              <p class='text-muted-foreground mt-2'>{step.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class='bg-background py-16 sm:py-20 md:py-24 lg:py-32'>
    <div class='container'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Enterprise-Grade Solutions</h2>
      </div>

      <div class='mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3'>
        {
          features.map((feature) => (
            <div class='bg-muted rounded-2xl p-8'>
              <div class='bg-primary/10 flex h-12 w-12 items-center justify-center rounded-lg'>
                <Icon name={feature.icon} class='text-primary h-6 w-6' />
              </div>
              <h3 class='text-foreground mt-6 text-xl font-semibold'>{feature.title}</h3>
              <p class='text-muted-foreground mt-2'>{feature.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section class='bg-muted py-16 sm:py-20'>
    <div class='container'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Success Stories</h2>
        <p class='text-muted-foreground mt-4 text-lg'>Real solutions for real businesses</p>
      </div>

      <div class='mt-16 grid gap-8 sm:grid-cols-2'>
        {
          caseStudies.map((study) => (
            <div class='bg-background overflow-hidden rounded-2xl'>
              <img src={study.image} alt={study.title} class='h-48 w-full object-cover' />
              <div class='p-6'>
                <h3 class='text-foreground text-xl font-semibold'>{study.title}</h3>
                <p class='text-muted-foreground mt-2'>{study.description}</p>
                <p class='text-success mt-4'>{study.results}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Technical Stack -->
  <section class='bg-background py-16 sm:py-20'>
    <div class='container'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Enterprise-Grade Technology Stack</h2>
        <p class='text-muted-foreground mt-4 text-lg'>Modern technologies for robust and scalable applications</p>
      </div>

      <div class='mt-16 grid gap-8 sm:grid-cols-3'>
        {
          techFeatures.map((tech) => (
            <div class='bg-muted rounded-2xl p-8'>
              <div class='bg-primary/10 flex h-12 w-12 items-center justify-center rounded-lg'>
                <Icon name={tech.icon} class='text-primary h-6 w-6' />
              </div>
              <h3 class='text-foreground mt-6 text-xl font-semibold'>{tech.category}</h3>
              <ul class='mt-4 space-y-2'>
                {tech.items.map((item) => (
                  <li class='flex items-center gap-2'>
                    <Icon name='lucide:check' class='text-primary h-4 w-4' />
                    <span class='text-muted-foreground'>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
