---
import Layout from '@/layouts/layout.astro';
import { Icon } from 'astro-icon/components';
import Top from '@/components/top.astro';

const services = [
  {
    title: 'Search Engine Optimization',
    description: 'Improve your visibility in search results and drive organic traffic.',
    icon: 'lucide:search',
  },
  {
    title: 'Content Marketing',
    description: 'Engaging content that attracts and retains your target audience.',
    icon: 'lucide:file-text',
  },
  {
    title: 'Social Media Marketing',
    description: 'Build your brand presence across social media platforms.',
    icon: 'lucide:share-2',
  },
  {
    title: 'Email Marketing',
    description: 'Strategic email campaigns that nurture leads and drive conversions.',
    icon: 'lucide:mail',
  },
  {
    title: 'PPC Advertising',
    description: 'Targeted paid campaigns across Google, Facebook, and Instagram.',
    icon: 'lucide:target',
  },
  {
    title: 'Analytics & Reporting',
    description: 'Data-driven insights to optimize your marketing strategy.',
    icon: 'lucide:bar-chart-2',
  },
];

const caseStudies = [
  {
    client: 'Local Restaurant',
    results: 'Increased online orders by 150%',
    strategy: 'Social media + Local SEO',
    image: 'https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?q=80&w=1000',
  },
  {
    client: 'E-commerce Store',
    results: '200% ROI on ad spend',
    strategy: 'PPC + Email Marketing',
    image: 'https://images.unsplash.com/photo-1472851294608-062f824d29cc?q=80&w=1000',
  },
  {
    client: 'B2B Service Provider',
    results: '75% more qualified leads',
    strategy: 'Content Marketing + SEO',
    image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=1000',
  },
];

const marketingMetrics = [
  {
    metric: 'Keyword Rankings',
    improvement: '↑ 45%',
    description: 'Average improvement in search positions',
  },
  {
    metric: 'Conversion Rate',
    improvement: '↑ 85%',
    description: 'Increase in website conversions',
  },
  {
    metric: 'Social Engagement',
    improvement: '↑ 125%',
    description: 'Growth in social media interaction',
  },
];
---

<Layout
  title='Marketing'
  description='Boost your online presence with our comprehensive digital marketing services. SEO, social media, content marketing, and more.'
>
  <Top
    title='Transform Your Digital Presence'
    description='Data-driven digital marketing strategies that deliver measurable results for your business.'
  />

  <!-- Services Grid -->
  <section class='bg-background py-16 sm:py-20'>
    <div class='container'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Comprehensive Marketing Solutions</h2>
        <p class='text-muted-foreground mt-4 text-lg'>
          Strategic digital marketing services tailored to your business goals
        </p>
      </div>
      <div class='mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3'>
        {
          services.map((service) => (
            <div class='bg-muted rounded-2xl p-8'>
              <div class='bg-primary/10 flex h-12 w-12 items-center justify-center rounded-lg'>
                <Icon name={service.icon} class='text-primary h-6 w-6' />
              </div>
              <h3 class='text-foreground mt-6 text-xl font-semibold'>{service.title}</h3>
              <p class='text-muted-foreground mt-2'>{service.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Case Studies -->
  <section class='bg-muted py-16 sm:py-20'>
    <div class='container'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Client Success Stories</h2>
        <p class='text-muted-foreground mt-4 text-lg'>Real results for real businesses</p>
      </div>
      <div class='mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3'>
        {
          caseStudies.map((study) => (
            <div class='bg-background overflow-hidden rounded-2xl'>
              <img src={study.image} alt={study.client} class='h-48 w-full object-cover' />
              <div class='p-6'>
                <h3 class='text-foreground text-xl font-semibold'>{study.client}</h3>
                <p class='text-success mt-2'>{study.results}</p>
                <p class='text-muted-foreground mt-2'>{study.strategy}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Marketing Metrics -->
  <section class='bg-background py-16 sm:py-20'>
    <div class='container'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>
          Performance That Speaks For Itself
        </h2>
        <p class='text-muted-foreground mt-4 text-lg'>Average results across our client portfolio</p>
      </div>
      <div class='mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3'>
        {
          marketingMetrics.map((item) => (
            <div class='bg-muted rounded-2xl p-8 text-center'>
              <h3 class='text-primary text-2xl font-bold'>{item.improvement}</h3>
              <p class='text-foreground mt-2 font-semibold'>{item.metric}</p>
              <p class='text-muted-foreground mt-2'>{item.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- SEO Process -->
  <section class='bg-muted py-16 sm:py-20'>
    <div class='container'>
      <div class='mx-auto max-w-3xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Our Marketing Process</h2>
        <p class='text-muted-foreground mt-4 text-lg'>A data-driven approach to growing your online presence</p>
        <ul class='mt-8 space-y-4 text-left'>
          <li class='flex items-start gap-3'>
            <Icon name='lucide:search' class='text-primary mt-1 h-5 w-5' />
            <div>
              <span class='text-foreground font-semibold'>Research & Analysis</span>
              <p class='text-muted-foreground'>Deep dive into your industry, competitors, and target audience</p>
            </div>
          </li>
          <li class='flex items-start gap-3'>
            <Icon name='lucide:puzzle' class='text-primary mt-1 h-5 w-5' />
            <div>
              <span class='text-foreground font-semibold'>Strategy Development</span>
              <p class='text-muted-foreground'>Custom marketing plan aligned with your goals</p>
            </div>
          </li>
          <li class='flex items-start gap-3'>
            <Icon name='lucide:rocket' class='text-primary mt-1 h-5 w-5' />
            <div>
              <span class='text-foreground font-semibold'>Implementation</span>
              <p class='text-muted-foreground'>Execute strategies across all channels</p>
            </div>
          </li>
          <li class='flex items-start gap-3'>
            <Icon name='lucide:bar-chart' class='text-primary mt-1 h-5 w-5' />
            <div>
              <span class='text-foreground font-semibold'>Monitor & Optimize</span>
              <p class='text-muted-foreground'>Continuous tracking and improvement of campaign performance</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Layout>
