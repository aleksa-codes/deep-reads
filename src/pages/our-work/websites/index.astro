---
import Layout from '@/layouts/layout.astro';
import Pricing from '@/components/sections/Pricing.astro';
import { Icon } from 'astro-icon/components';
import Top from '@/components/top.astro';

const features = [
  {
    title: 'Custom Website Design',
    description: 'Unique, hand-crafted designs that reflect your brand identity and business goals.',
    icon: 'lucide:palette',
  },
  {
    title: 'Mobile Responsive',
    description: 'Websites that look and function perfectly on all devices and screen sizes.',
    icon: 'lucide:smartphone',
  },
  {
    title: 'SEO Optimized',
    description: 'Built with search engines in mind to help improve your online visibility.',
    icon: 'lucide:search',
  },
  {
    title: 'Performance Optimization',
    description: 'Lightning-fast websites optimized for speed and core web vitals.',
    icon: 'lucide:gauge',
  },
  {
    title: 'Content Management',
    description: 'Easy-to-use CMS for updating your website content.',
    icon: 'lucide:edit-3',
  },
  {
    title: 'Analytics Integration',
    description: 'Built-in tracking and reporting to monitor your website performance.',
    icon: 'lucide:bar-chart',
  },
];

const portfolioItems = [
  {
    title: 'E-commerce Website',
    description: 'Full-featured online store with custom product layouts',
    image: 'https://images.unsplash.com/photo-1661956602116-aa6865609028?q=80&w=1000',
  },
  {
    title: 'Corporate Website',
    description: 'Professional business presence with modern design',
    image: 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=1000',
  },
  {
    title: 'Restaurant Website',
    description: 'Interactive menu and reservation system',
    image: 'https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?q=80&w=1000',
  },
];

const processSteps = [
  {
    step: '01',
    title: 'Discovery',
    description: 'We analyze your business needs and target audience.',
  },
  {
    step: '02',
    title: 'Design',
    description: 'Create a custom design that matches your brand.',
  },
  {
    step: '03',
    title: 'Development',
    description: 'Build your website using modern technologies.',
  },
  {
    step: '04',
    title: 'Launch',
    description: 'Test, optimize, and deploy your website.',
  },
];

const industries = [
  {
    name: 'E-commerce',
    description: 'Online stores with secure payment processing',
    icon: 'lucide:shopping-cart',
  },
  {
    name: 'Healthcare',
    description: 'HIPAA-compliant medical websites',
    icon: 'lucide:heart-pulse',
  },
  {
    name: 'Real Estate',
    description: 'Property listing and management sites',
    icon: 'lucide:home',
  },
];

const metrics = [
  {
    number: '99%',
    label: 'Page Speed Score',
  },
  {
    number: '100%',
    label: 'Mobile Responsive',
  },
  {
    number: '50%',
    label: 'Avg. Traffic Increase',
  },
];
---

<Layout
  title='Websites'
  description='Expert website development services offering custom designs, responsive layouts, and SEO optimization. Transform your online presence with our professional web solutions.'
>
  <Top
    title='Websites That Drive Results'
    description='From simple business websites to complex e-commerce solutions, we create websites that convert visitors into customers.'
  />

  <section class='bg-muted py-16 sm:py-20'>
    <div class='container'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Our Website Development Process</h2>
        <p class='text-muted-foreground mt-4 text-lg'>A streamlined approach to delivering exceptional websites</p>
      </div>

      <div class='mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4'>
        {
          processSteps.map((step) => (
            <div class='bg-background relative rounded-2xl p-8'>
              <span class='text-primary absolute -top-4 left-4 text-5xl font-bold'>{step.step}</span>
              <h3 class='text-foreground mt-4 text-xl font-semibold'>{step.title}</h3>
              <p class='text-muted-foreground mt-2'>{step.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class='bg-background py-16 sm:py-20 md:py-24 lg:py-32'>
    <div class='container'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>
          Everything You Need in a Modern Website
        </h2>
      </div>

      <div class='mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3'>
        {
          features.map((feature) => (
            <div class='bg-muted rounded-2xl p-8'>
              <div class='bg-primary/10 flex h-12 w-12 items-center justify-center rounded-lg'>
                <Icon name={feature.icon} class='text-primary h-6 w-6' />
              </div>
              <h3 class='text-foreground mt-6 text-xl font-semibold'>{feature.title}</h3>
              <p class='text-muted-foreground mt-2'>{feature.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class='bg-muted py-16 sm:py-20'>
    <div class='container'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Industries We Serve</h2>
        <p class='text-muted-foreground mt-4 text-lg'>Specialized website solutions for your industry</p>
      </div>

      <div class='mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3'>
        {
          industries.map((industry) => (
            <div class='bg-background rounded-2xl p-8'>
              <div class='bg-primary/10 flex h-12 w-12 items-center justify-center rounded-lg'>
                <Icon name={industry.icon} class='text-primary h-6 w-6' />
              </div>
              <h3 class='text-foreground mt-6 text-xl font-semibold'>{industry.name}</h3>
              <p class='text-muted-foreground mt-2'>{industry.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class='bg-background py-16 sm:py-20'>
    <div class='container'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Website Performance Metrics</h2>
        <p class='text-muted-foreground mt-4 text-lg'>Our websites are built for speed, security, and success</p>
      </div>

      <div class='mt-16 grid gap-8 sm:grid-cols-3'>
        {
          metrics.map((metric) => (
            <div class='text-center'>
              <p class='text-primary text-4xl font-bold'>{metric.number}</p>
              <p class='text-muted-foreground mt-2 text-lg'>{metric.label}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class='bg-muted py-16 sm:py-20 md:py-24 lg:py-32'>
    <div class='container'>
      <div class='mx-auto max-w-2xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Our Recent Work</h2>
      </div>

      <div class='mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3'>
        {
          portfolioItems.map((item) => (
            <div class='bg-background overflow-hidden rounded-2xl'>
              <img src={item.image} alt={item.title} class='h-48 w-full object-cover' />
              <div class='p-6'>
                <h3 class='text-foreground text-xl font-semibold'>{item.title}</h3>
                <p class='text-muted-foreground mt-2'>{item.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <Pricing background='background' />

  <section class='bg-muted py-16 sm:py-20'>
    <div class='container'>
      <div class='mx-auto max-w-3xl text-center'>
        <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Built for Search Engines</h2>
        <p class='text-muted-foreground mt-4 text-lg'>
          Every website we build is optimized for search engines, helping you rank higher and attract more visitors
        </p>
        <ul class='mt-8 space-y-4 text-left'>
          <li class='flex items-center gap-3'>
            <Icon name='lucide:check' class='text-primary h-5 w-5' />
            <span>Schema markup for better search visibility</span>
          </li>
          <li class='flex items-center gap-3'>
            <Icon name='lucide:check' class='text-primary h-5 w-5' />
            <span>Optimized meta tags and content structure</span>
          </li>
          <li class='flex items-center gap-3'>
            <Icon name='lucide:check' class='text-primary h-5 w-5' />
            <span>Mobile-first design for better rankings</span>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Layout>
