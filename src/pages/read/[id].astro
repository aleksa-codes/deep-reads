---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '@/layouts/layout.astro';
import { Icon } from 'astro-icon/components';
import LikeButton from '@/components/like-button';

export async function getStaticPaths() {
  const reads = await getCollection('reads');
  return reads.map((read) => ({
    params: { id: read.id },
    props: { readId: read.id },
  }));
}

const { readId } = Astro.props;
const read = await getEntry('reads', readId);
if (!read) return Astro.redirect('/404');

// Fetch all tags to get the display title from a slug
const allTags = await getCollection('tags');
const tagMap = new Map(allTags.map((t) => [t.id, t.data.title]));

const { Content } = await render(read);

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
};
---

<Layout title={`${read.data.title}`} description={read.data.summary || `Read about ${read.data.title}`}>
  {/* Using max-w-3xl for the article itself provides optimal line length for readability. */}
  <!-- ARTICLE HEADER: Clean, with strong typographic hierarchy. -->
  <header class='border-border mb-8 border-b pb-8'>
    <!-- Metadata: Subtle, using sans-serif for clarity. -->
    <div class='text-muted-foreground mb-4 flex flex-wrap items-center gap-x-4 font-sans text-sm'>
      <time datetime={read.data.dateAdded.toISOString()}>{formatDate(read.data.dateAdded)}</time>
      {read.data.tags.length > 0 && <span aria-hidden='true'>•</span>}
      <div class='flex flex-wrap items-center gap-x-3'>
        {
          read.data.tags.map((tagSlug) => {
            const tagTitle = tagMap.get(tagSlug);
            if (!tagTitle) return null;
            return (
              <a href={`/tags/${tagSlug}/`} class='hover:text-primary transition-colors'>
                {tagTitle}
              </a>
            );
          })
        }
      </div>
    </div>

    <!-- Headline: Large, serif font for an elegant, editorial feel. -->
    <h1 class='text-foreground font-serif text-4xl leading-tight font-bold tracking-tight sm:text-5xl'>
      {read.data.title}
    </h1>

    <!-- Summary/Deck: Provides context, with a slightly larger font size than the body. -->
    {read.data.summary && <p class='text-muted-foreground mt-4 text-xl'>{read.data.summary}</p>}
  </header>

  <!-- MAIN CONTENT: Styled with `prose` for optimal readability. -->
  <div
    class='prose prose-lg dark:prose-invert prose-p:text-foreground/90 prose-headings:font-serif prose-headings:text-foreground prose-a:text-primary prose-strong:text-foreground max-w-none'
  >
    <Content />
  </div>

  <!-- POST-ARTICLE FOOTER: Contains actions and source info, cleanly separated. -->
  <footer class='border-border mt-12 border-t pt-8'>
    <div class='flex flex-col items-start gap-6 sm:flex-row sm:items-center sm:justify-between'>
      <!-- Actions are grouped and made more subtle. -->
      <div class='flex items-center gap-2'>
        <LikeButton client:load readId={read.id} />

        <a
          href='#'
          aria-label='Share this article'
          class='text-muted-foreground hover:text-primary inline-flex h-10 w-10 items-center justify-center rounded-full transition-colors'
        >
          <Icon name='lucide:share-2' class='h-5 w-5' />
        </a>
      </div>

      <!-- The "Read Original" link is the primary CTA, styled consistently. -->
      <a
        href={read.data.url}
        target='_blank'
        rel='noopener noreferrer'
        class='group text-primary inline-flex items-center text-base font-medium'
      >
        <span>Read the original story</span>
        <Icon name='lucide:arrow-right' class='ml-1.5 h-4 w-4 transition-transform group-hover:translate-x-1' />
      </a>
    </div>

    <!-- Source info is integrated subtly as a footnote. -->
    <p class='text-muted-foreground mt-6 text-center text-sm sm:text-left'>
      Originally published at <a
        href={read.data.url}
        target='_blank'
        rel='noopener noreferrer'
        class='hover:text-primary'>{new URL(read.data.url).hostname.replace('www.', '')}</a
      >.
    </p>
  </footer>
</Layout>
