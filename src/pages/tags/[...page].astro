---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/layout.astro';
import { tagToSlug } from '@/lib/utils';
import Badge from '@/components/ui/badge.astro';
import Button from '@/components/ui/button.astro';
import Pagination from '@/components/ui/pagination.astro';
import { Icon } from 'astro-icon/components';
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const reads = await getCollection('reads');
  const allTags = [...new Set(reads.flatMap((read) => read.data.tags || []))].sort();

  const tagCounts = allTags.map((tag) => ({
    tag,
    count: reads.filter((read) => read.data.tags.includes(tag)).length,
    recentReads: reads
      .filter((read) => read.data.tags.includes(tag))
      .sort((a, b) => b.data.dateAdded.valueOf() - a.data.dateAdded.valueOf())
      .slice(0, 3),
  }));

  const sortedTags = tagCounts.sort((a, b) => b.count - a.count);

  return paginate(sortedTags, {
    pageSize: 9,
    props: { totalReads: reads.length, allTagsCount: allTags.length },
  });
}) satisfies GetStaticPaths;

// type Params = InferGetStaticParamsType<typeof getStaticPaths>;
type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page, totalReads, allTagsCount } = Astro.props as Props;
---

<Layout title='Browse Tags - DeepReads' description='Explore all topics and tags on DeepReads' hideCTA={true}>
  <div class='container mx-auto px-4 py-10'>
    <!-- Page Header -->
    <div class='mb-8 text-center'>
      <h2 class='text-foreground text-3xl font-bold tracking-tight sm:text-4xl'>Explore Topics</h2>
      <p class='text-muted-foreground mt-2 text-lg'>
        Page {page.currentPage} of {page.lastPage} • Discover content from {allTagsCount} unique tags.
      </p>
    </div>

    <div class='mx-auto max-w-7xl'>
      <!-- Stats Section -->
      <div class='mb-12 grid grid-cols-1 gap-6 text-center md:grid-cols-3'>
        <div class='bg-card rounded-xl border p-6 shadow-sm'>
          <h3 class='text-muted-foreground text-sm font-medium uppercase'>Total Tags</h3>
          <p class='text-foreground mt-2 text-4xl font-bold tracking-tight'>{allTagsCount}</p>
        </div>
        <div class='bg-card rounded-xl border p-6 shadow-sm'>
          <h3 class='text-muted-foreground text-sm font-medium uppercase'>Total Reads</h3>
          <p class='text-foreground mt-2 text-4xl font-bold tracking-tight'>{totalReads}</p>
        </div>
        <div class='bg-card rounded-xl border p-6 shadow-sm'>
          <h3 class='text-muted-foreground text-sm font-medium uppercase'>Top Tag Posts</h3>
          <p class='text-foreground mt-2 text-4xl font-bold tracking-tight'>{page.data[0]?.count || 0}</p>
        </div>
      </div>

      <!-- Tags Grid -->
      <div class='grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3'>
        {
          page.data.map(({ tag, count, recentReads }) => (
            <a
              href={`/tags/${tagToSlug(tag)}/`}
              class='group bg-card hover:border-primary flex flex-col justify-between rounded-xl border p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg'
            >
              <div>
                <div class='mb-4 flex items-start justify-between gap-4'>
                  <h3 class='text-foreground group-hover:text-primary text-xl font-semibold'>{tag}</h3>
                  <Badge variant='secondary'>{count} posts</Badge>
                </div>
                <div class='border-t pt-4'>
                  <h4 class='text-muted-foreground mb-3 text-sm font-medium'>Recent in this topic:</h4>
                  <div class='space-y-3'>
                    {recentReads.map((read) => (
                      <div class='flex items-start gap-2 text-sm'>
                        <Icon name='lucide:file-text' class='text-muted-foreground mt-0.5 h-4 w-4 shrink-0' />
                        <span class='text-secondary-foreground line-clamp-2'>{read.data.title}</span>
                      </div>
                    ))}
                    {count > 3 && <div class='text-muted-foreground pt-2 text-xs'>+ {count - 3} more</div>}
                  </div>
                </div>
              </div>
            </a>
          ))
        }
      </div>

      <!-- Empty State -->
      {
        page.data.length === 0 && (
          <div class='bg-muted/50 mt-16 flex flex-col items-center justify-center rounded-lg border-2 border-dashed py-24 text-center'>
            <Icon name='lucide:tag' class='text-muted-foreground h-12 w-12' />
            <h2 class='text-foreground mt-4 text-2xl font-semibold tracking-tight'>No Tags Found</h2>
            <p class='text-muted-foreground mt-2'>It looks like there are no tags to display right now.</p>
            <Button href='/' variant='default' class='mt-6'>
              <Icon name='lucide:arrow-left' class='mr-2 h-4 w-4' />
              Go Back to Reads
            </Button>
          </div>
        )
      }

      <!-- Pagination -->
      {
        page.lastPage > 1 && (
          <div class='mt-12'>
            <Pagination {page} />
          </div>
        )
      }
    </div>
  </div>
</Layout>
