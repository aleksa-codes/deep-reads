---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/layout.astro';
import Badge from '@/components/ui/badge.astro';
import Pagination from '@/components/ui/pagination.astro';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const allReads = await getCollection('reads');
  const allTags = await getCollection('tags');

  const tagData = allTags.map((tag) => {
    const relatedReads = allReads.filter((read) => read.data.tags.includes(tag.id));
    return {
      title: tag.data.title,
      slug: tag.id,
      count: relatedReads.length,
      recentReads: relatedReads.sort((a, b) => b.data.dateAdded.valueOf() - a.data.dateAdded.valueOf()).slice(0, 3),
    };
  });

  const sortedTags = tagData.sort((a, b) => b.count - a.count);

  return paginate(sortedTags, {
    pageSize: 9,
    props: { totalReads: allReads.length, allTagsCount: allTags.length },
  });
}) satisfies GetStaticPaths;

const { page, totalReads, allTagsCount } = Astro.props;
---

<Layout title='Browse Topics' description='Explore all topics and tags on DeepReads'>
  <!-- PAGE HEADER: Uses serif font for the main title for an editorial feel. -->
  <header class='mb-12 text-center'>
    <h1 class='text-foreground font-serif text-4xl font-bold tracking-tight sm:text-5xl'>Explore Topics</h1>
    <!-- STATS: Integrated into a clean, single line of text instead of heavy cards. -->
    <p class='text-muted-foreground mt-4 text-lg'>
      Discover {allTagsCount} topics across {totalReads} articles.
    </p>
  </header>

  <!-- GRID OF TAGS: Uses a responsive grid with ample spacing. -->
  <div class='grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3'>
    {
      page.data.map(({ title, slug, count, recentReads }) => (
        // TAG CARD: The entire card is a link, with a simple border and a subtle background change on hover.
        // This removes the distracting shadow and lift effect.
        <a
          href={`/tags/${slug}/`}
          class='group border-border hover:border-primary hover:bg-muted/50 block rounded-lg border bg-transparent p-6 transition-colors'
        >
          <div class='flex items-start justify-between gap-4'>
            {/* Tag title is the primary element. */}
            <h2 class='text-foreground group-hover:text-primary text-xl font-bold transition-colors'>{title}</h2>
            {/* A subtle badge for the post count. */}
            <Badge variant='secondary' class='shrink-0 font-medium'>
              <span>{count}</span>
              <span>{count === 1 ? 'Article' : 'Articles'}</span>
            </Badge>
          </div>

          {/* List of recent reads. The top border is removed for a cleaner look. */}
          <div class='mt-4 space-y-2 pt-4'>
            {recentReads.length > 0 ? (
              recentReads.map((read) => (
                // Each recent read is just a clean line of text. The icon is removed to reduce clutter.
                <p class='text-muted-foreground line-clamp-2 text-sm'>{read.data.title}</p>
              ))
            ) : (
              <p class='text-muted-foreground text-sm'>No recent articles in this topic.</p>
            )}
          </div>
        </a>
      ))
    }
  </div>

  <!-- PAGINATION: Centered with ample top margin for separation. -->
  {
    page.lastPage > 1 && (
      <div class='mt-16'>
        <Pagination {page} />
      </div>
    )
  }
</Layout>
